# Server
PORT=8080

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# Rate limiting: max requests per window per IP
RATELIMIT_MAX=60
# Window in seconds
RATELIMIT_WINDOW=60

# Proxy for unofficial API requests (Twitter, Reddit, Steam, Discord)
# Supports http/https/socks5  e.g. http://user:pass@host:port
PROXY_URL=

# Discord Bot Token (required for Discord lookups)
DISCORD_BOT_TOKEN=

# Twitch Client ID + Secret (required for Twitch lookups)
# Get one at https://dev.twitch.tv/console
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=